APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/skills_store
ALEMBIC_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/skills_store
JWT_SECRET=change-me
JWT_EXPIRE_HOURS=24
PACKAGE_STORAGE_MODE=local
PACKAGE_STORAGE_ROOT=./data/packages
ED25519_PRIVATE_KEY_PATH=./secrets/ed25519-private.pem
ED25519_PUBLIC_KEY_ID=ed25519-main
