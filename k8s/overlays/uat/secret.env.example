# Copy this file to secret.env and fill in the real values.
# secret.env is gitignored — never commit it.
#
# Usage:
#   cp secret.env.example secret.env
#   # edit secret.env with actual credentials
#   kubectl kustomize overlays/uat | kubectl apply -f -

# ===========================================================================
# MCP Server — 数据库（socialhub_mcp 库，Azure Database for PostgreSQL）
# 格式：postgresql+asyncpg://<user>%40<server>:<password>@<host>:5432/socialhub_mcp?ssl=require
# ===========================================================================
MCP_DATABASE_URL=postgresql+asyncpg://<user>%40<server>:<password>@<host>.postgres.database.azure.com:5432/socialhub_mcp?ssl=require

# ===========================================================================
# MCP Server — 认证
# ===========================================================================
# HTTP 模式 API Key 映射（格式: key:tenant_id，多个用逗号分隔）
MCP_API_KEYS=<your-api-key>:<tenant-id>

# Fernet 加密 key（生成命令：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"）
CREDENTIAL_ENCRYPT_KEY=<your-fernet-key>

# 门户 JWT 签名密钥（未设置则随机生成，重启后门户会话失效）
PORTAL_JWT_SECRET=<your-portal-jwt-secret>

# ===========================================================================
# MCP Server — 上游 SocialHub 服务
# ===========================================================================
SOCIALHUB_AUTH_URL=<your-socialhub-auth-url>
MCP_SSE_URL=<your-mcp-sse-url>
MCP_POST_URL=<your-mcp-post-url>
# 格式: tenant_id:app_id:app_secret（留空则用 Portal DB 配置）
MCP_TENANT_CREDS=

# ===========================================================================
# Skills Store — 数据库（skills_store 库，Azure Database for PostgreSQL）
# ===========================================================================
SKILLS_DATABASE_URL=postgresql+asyncpg://<user>%40<server>:<password>@<host>.postgres.database.azure.com:5432/skills_store?ssl=require
SKILLS_ALEMBIC_DATABASE_URL=postgresql+psycopg://<user>%40<server>:<password>@<host>.postgres.database.azure.com:5432/skills_store?sslmode=require

# ===========================================================================
# Skills Store — 认证
# ===========================================================================
SKILLS_JWT_SECRET=<your-skills-jwt-secret>

# ===========================================================================
# Skills Store — 初始管理员账号（可选，留空则跳过）
# ===========================================================================
SKILLS_ADMIN_EMAIL=admin@example.com
SKILLS_ADMIN_PASSWORD=<your-admin-password>

# ===========================================================================
# Emarsys Sync — StarRocks 连接
# ===========================================================================
STARROCKS_HOST=<your-starrocks-host>
STARROCKS_USER=<your-starrocks-user>
STARROCKS_PASSWORD=<your-starrocks-password>