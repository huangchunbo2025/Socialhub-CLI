# .env.docker.example — docker-compose 容器运行环境变量完整参考
# 使用方式：cp .env.docker.example .env.docker，填写实际值后 docker compose up -d
# 适用场景：docker-compose 本地/自托管部署（mcp-server + skills-store-backend）
#
# 注意：DATABASE_URL 不在此处配置，由 docker-compose.yml 各服务按容器网络分别覆盖：
#   mcp-server           → postgresql+asyncpg://postgres:<POSTGRES_PASSWORD>@postgres:5432/socialhub_mcp
#   skills-store-backend → postgresql+asyncpg://postgres:<POSTGRES_PASSWORD>@postgres:5432/skills_store

# ===========================================================================
# PostgreSQL 共享实例
# ===========================================================================

POSTGRES_PASSWORD=postgres

# ===========================================================================
# MCP Server — 认证
# ===========================================================================

# HTTP 模式 API Key 映射（格式: key:tenant_id，多个用逗号分隔）
MCP_API_KEYS=sapbigquerytest:uat

# stdio 模式单租户兼容（HTTP 模式优先使用 MCP_API_KEYS）
MCP_TENANT_ID=

# Fernet 加密 key（用 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 生成）
CREDENTIAL_ENCRYPT_KEY=SjsTeFJa2aF2h5IvXaunrIcXJppQXfCrC3Raqlq5YMg=

# MCP Server 门户 JWT 签名密钥（用于 /auth/login 颁发的会话 token，未设置则随机生成，重启后门户会话失效）
# 注意：与下方 Skills Store 的 JWT_SECRET 是两个独立的密钥，不可混用
PORTAL_JWT_SECRET=local-dev-secret-2026

# ===========================================================================
# MCP Server — SocialHub 上游服务
# ===========================================================================

# SocialHub 认证 API（门户登录 + App Token 获取）
SOCIALHUB_AUTH_URL=http://192.168.1.16:30833/openapi-uat

# MCP_AUTH_URL 仅覆盖 token_manager 的 auth_url，优先级高于 SOCIALHUB_AUTH_URL
# MCP_AUTH_URL=

# 上游 MCP Analytics Gateway 端点
MCP_SSE_URL=http://192.168.1.16:30833/mcpgateway-uat/mcp/analytics-db/sse
MCP_POST_URL=http://192.168.1.16:30833/mcpgateway-uat/mcp/analytics-db/message

# SocialHub App 凭证 fallback（优先级低于 Portal DB 配置）
# 格式: tenant_id:app_id:app_secret
MCP_TENANT_CREDS=

# ===========================================================================
# MCP Server — 数据库路由
# ===========================================================================

# 各租户库映射（格式: tenant_id:database，多个用逗号分隔）
# 不配置则默认 das_{tenant_id} / dts_{tenant_id} / datanow_{tenant_id}
DAS_DATABASE=uat:das_test
DTS_DATABASE=uat:dts_test
DATANOW_DATABASE=uat:datanow_test

# SQL 显式表路由（优先级高于前缀规则，格式: table1,table2,prefix_*）
DAS_TABLES=
DTS_TABLES=
DATANOW_TABLES=ads_v_rfm

# 传递给上游 MCP gateway 的默认库名（通常不需要）
# MCP_DATABASE=

# ===========================================================================
# MCP Server — HTTP 部署
# ===========================================================================

# 额外允许的 CORS origin（逗号分隔，追加到代码默认白名单 localhost:3000/8080 + inspector）
# 生产环境如需开放前端域名，在此填入；留空则只允许默认白名单
ALLOWED_ORIGINS=

# ===========================================================================
# Emarsys Sync — StarRocks 连接
# ===========================================================================

# StarRocks FE/BE 主机（emarsys-sync 直连 BE HTTP port 8040，无需经 FE 重定向）
# STARROCKS_HOST: FE 主机，用于 MySQL 协议（DDL / 查询），端口 9030
STARROCKS_HOST=192.168.1.51
STARROCKS_PORT=9030
# STARROCKS_STREAM_LOAD_HOST: BE 主机，用于 HTTP Stream Load，端口 8040
# FE 会把 Stream Load 重定向到 BE，httpx 重定向时会丢失 Authorization 头
# 建议直接填 BE 地址，留空则与 STARROCKS_HOST 相同
STARROCKS_STREAM_LOAD_HOST=192.168.1.36
STARROCKS_HTTP_PORT=8040
STARROCKS_USER=dev
STARROCKS_PASSWORD=dev1234

# ===========================================================================
# Skills Store Backend
# ===========================================================================

# Skills Store JWT 签名密钥（与上方 MCP Server 的 PORTAL_JWT_SECRET 无关，各自独立）
# render.yaml 使用 generateValue: true 自动生成；本地需手动设置
JWT_SECRET=local-dev-secret-2026

# 初始管理员账号（可选，首次启动时自动创建；留空则跳过）
ADMIN_EMAIL=
ADMIN_PASSWORD=
