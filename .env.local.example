# .env.local.example — 本地开发环境变量完整参考
# 使用方式：cp .env.local.example .env.local，填写实际值
# 适用场景：CLI 直跑 + MCP Server 本地 uvicorn 启动（非 Docker）

# ===========================================================================
# MCP Server — 数据库连接
# ===========================================================================

# PostgreSQL 连接串（本地直跑；Docker 容器内由 docker-compose 覆盖）
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/socialhub_mcp

# ===========================================================================
# MCP Server — 认证
# ===========================================================================

# HTTP 模式 API Key 映射（格式: key:tenant_id，多个用逗号分隔）
MCP_API_KEYS=sh_your_key_here:uat

# stdio 模式单租户（HTTP 模式优先使用 MCP_API_KEYS 中的 tenant_id）
MCP_TENANT_ID=

# Fernet 加密 key（加密存储凭证，用 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 生成）
CREDENTIAL_ENCRYPT_KEY=

# JWT 签名密钥（门户登录 Session，未设置则随机生成，重启后会话失效）
PORTAL_JWT_SECRET=

# ===========================================================================
# MCP Server — SocialHub 上游服务
# ===========================================================================

# SocialHub 认证 API（门户登录 + App Token 获取）
SOCIALHUB_AUTH_URL=http://your-host/openapi-uat

# MCP_AUTH_URL 仅覆盖 token_manager 的 auth_url，优先级高于 SOCIALHUB_AUTH_URL
# MCP_AUTH_URL=

# 上游 MCP Analytics Gateway 端点
MCP_SSE_URL=http://your-host/mcpgateway-uat/mcp/analytics-db/sse
MCP_POST_URL=http://your-host/mcpgateway-uat/mcp/analytics-db/message

# SocialHub App 凭证 fallback（优先级低于 Portal DB 配置）
# 格式: tenant_id:app_id:app_secret，多个用逗号分隔
# MCP_TENANT_CREDS=uat:your_app_id:your_app_secret

# ===========================================================================
# MCP Server — 数据库路由
# ===========================================================================

# 各租户库映射（格式: tenant_id:database，多个用逗号分隔）
# 不配置则默认 das_{tenant_id} / dts_{tenant_id} / datanow_{tenant_id}
DAS_DATABASE=uat:das_uat
DTS_DATABASE=uat:dts_uat
DATANOW_DATABASE=uat:datanow_uat

# SQL 显式表路由（优先级高于前缀规则，格式: table1,table2,prefix_*）
# 用于处理不符合标准前缀（ads_/dwd_/dim_/dws_/vdm_/t_/v_）的特殊表名
# DAS_TABLES=special_table,custom_report_*
DAS_TABLES=
DTS_TABLES=
DATANOW_TABLES=

# 传递给上游 MCP gateway 的默认库名（通常不需要，由路由规则替代）
# MCP_DATABASE=

# ===========================================================================
# MCP Server — HTTP 部署
# ===========================================================================

# 额外允许的 CORS origin（逗号分隔，追加到代码白名单）
# ALLOWED_ORIGINS=https://your-frontend.com

# ===========================================================================
# CLI — AI 配置（自然语言解析用，仅 CLI 本地运行需要）
# ===========================================================================

# AI 提供商：azure（默认）或 openai
AI_PROVIDER=azure

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# 切换为 OpenAI 时使用
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# ===========================================================================
# CLI — API 模式（mode=api 时使用，通常不需要）
# ===========================================================================

# SOCIALHUB_API_URL=https://api.socialhub.ai
# SOCIALHUB_API_KEY=
# SOCIALHUB_MODE=mcp

# ===========================================================================
# CLI — 功能开关
# ===========================================================================

# Skills Store 演示模式（跳过签名验证，仅本地测试用）
# SOCIALHUB_DEMO_MODE=false

# ===========================================================================
# Snowflake 同步（socialhub mcp snowflake-sync，通常不需要）
# ===========================================================================

# SNOWFLAKE_ACCOUNT_LOCATOR=
# SNOWFLAKE_HOST=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_AUTHENTICATOR=snowflake
# SNOWFLAKE_SYNC_TABLE=MEMBERS_MVP
# SNOWFLAKE_SYNC_SORT_BY=
